# Supply-chain admission (constitution §4.6): quarantine newly published releases
# on the INSTALL path — resolution only picks versions published >= 2 days ago.
# Requires npm >= 11.10 (older npm ignores unknown keys; the Dependabot cooldown
# still covers the update path). Emergency bypass for urgent security fixes
# (§4.6.3): add the package to min-release-age-exclude with a rationale comment.
min-release-age=2
# Enforce the npm floor: min-release-age is silently ignored before npm 11.10,
# so engine-strict turns the engines.npm floor into a hard install error.
engine-strict=true
# Lifecycle scripts: npm offers only the all-or-nothing ignore-scripts, which
# would also disable this repo's own `prepare` hook (lefthook install). Limitation
# recorded per §4.6.2 — dependency scripts remain default-allow under npm.
# <<< claudeconf managed <<<
